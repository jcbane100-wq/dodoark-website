# Supabase - Get these from https://app.supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe - Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Site URL (for Stripe redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Management Panel API URL (for order delivery)
PANEL_API_URL=http://localhost:3001

# Discord webhook for purchase notifications (optional)
DISCORD_PURCHASE_WEBHOOK_URL=
